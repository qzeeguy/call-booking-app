#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/kill-port@1.6.1/node_modules/kill-port/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/kill-port@1.6.1/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/kill-port@1.6.1/node_modules/kill-port/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/kill-port@1.6.1/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../../../../../kill-port@1.6.1/node_modules/kill-port/cli.js" "$@"
else
  exec node  "$basedir/../../../../../../kill-port@1.6.1/node_modules/kill-port/cli.js" "$@"
fi
