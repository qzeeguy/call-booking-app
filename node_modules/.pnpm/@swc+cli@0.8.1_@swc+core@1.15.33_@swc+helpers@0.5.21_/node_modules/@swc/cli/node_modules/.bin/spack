#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/@swc+cli@0.8.1_@swc+core@1.15.33_@swc+helpers@0.5.21_/node_modules/@swc/cli/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/@swc+cli@0.8.1_@swc+core@1.15.33_@swc+helpers@0.5.21_/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/@swc+cli@0.8.1_@swc+core@1.15.33_@swc+helpers@0.5.21_/node_modules/@swc/cli/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/@swc+cli@0.8.1_@swc+core@1.15.33_@swc+helpers@0.5.21_/node_modules:/workspaces/qzeeco/call-booking-app/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../../bin/spack.js" "$@"
else
  exec node  "$basedir/../../bin/spack.js" "$@"
fi
